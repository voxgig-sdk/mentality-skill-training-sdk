                reqd: false
                type: "`$STRING`"
              }
              {
                kind: "query"
                name: "sport"
                orig: "sport"
                reqd: false
                type: "`$STRING`"
              }
            ]
          }
          method: "GET"
          orig: "/api/training-programs"
          parts: [
            "api"
            "training-programs"
          ]
          select: {
            exist: [
              "level"
              "sport"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



